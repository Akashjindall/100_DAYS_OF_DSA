#include <stdio.h>
#include <stdlib.h>

int compare(const void *a, const void *b) {
    return (*(int *)a - *(int *)b);
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    qsort(arr, n, sizeof(int), compare);

    int left = 0, right = n - 1;
    int minSum = abs(arr[left] + arr[right]);
    int first = arr[left], second = arr[right];

    while (left < right) {
        int sum = arr[left] + arr[right];

        if (abs(sum) < minSum) {
            minSum = abs(sum);
            first = arr[left];
            second = arr[right];
        }

        if (sum < 0)
            left++;
        else if (sum > 0)
            right--;
        else
            break; 
    }

    printf("%d %d\n", first, second);

    return 0;
}